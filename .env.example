# ---------------------------------------------------------------------------
# PeerConnect API — environment variables
# Copy this file to .env and fill in real values. Never commit .env.
# ---------------------------------------------------------------------------

# App
NODE_ENV=development
PORT=4000
# HOST — leave unset to bind to all network interfaces.
# Uncomment to bind to a specific interface (e.g. 127.0.0.1 or a LAN IP).
# HOST=0.0.0.0
API_VERSION=v1

# Database (PostgreSQL connection string used by Prisma)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/peerconnect?schema=public"

# CORS — comma-separated list of allowed origins, or * for all (dev only)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:19006

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Auth (Phase 2)
# ---------------------------------------------------------------------------

# Use long, random, unrelated secrets in real environments — e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-a-random-64-char-hex-string-for-access-tokens-xxxxxxxx
JWT_REFRESH_SECRET=replace-with-a-different-random-64-char-hex-string-refresh-xxxxx
JWT_ACCESS_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN_MS=604800000

BCRYPT_SALT_ROUNDS=12
PASSWORD_RESET_TOKEN_EXPIRES_IN_MINUTES=30

# University domains allowed for student registration (comma-separated)
ALLOWED_UNIVERSITY_DOMAINS=st.university.edu.gh,student.university.edu.gh,stu.ug.edu.gh,st.knust.edu.gh,st.uenr.edu.gh,st.ucc.edu.gh,st.umat.edu.gh,st.uhas.edu.gh,st.usted.edu.gh

# ---------------------------------------------------------------------------
# Cloudinary (Phase 3 — profile photo upload)
# Get these from https://cloudinary.com/console after creating a free account.
# ---------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_UPLOAD_FOLDER=peerconnect/profile-photos
MAX_PROFILE_PHOTO_SIZE_MB=5
CLOUDINARY_CHAT_UPLOAD_FOLDER=peerconnect/chat-images
MAX_CHAT_IMAGE_SIZE_MB=5
CLOUDINARY_ID_UPLOAD_FOLDER=peerconnect/id-verifications
MAX_ID_PHOTO_SIZE_MB=5

# ---------------------------------------------------------------------------
# Email (Phase 8 — Nodemailer)
# For local development, a free Ethereal test inbox works well:
# https://ethereal.email — generates disposable SMTP credentials with no
# real emails ever leaving the sandbox, and a link to view what was "sent."
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-ethereal-username
SMTP_PASSWORD=your-ethereal-password
EMAIL_FROM=PeerConnect <no-reply@peerconnect.app>
